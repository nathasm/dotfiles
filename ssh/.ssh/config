Compression yes
ControlMaster auto
ForwardAgent yes
HashKnownHosts yes
ServerAliveInterval 60
ServerAliveCountMax 3
AddKeysToAgent yes

Host diskstation
  HostName 192.168.0.2
  Port 2202
  User nsmith
  IdentityFile ~/.ssh/id_rsa_server

Host github.com
  HostName github.com
  IdentityFile ~/.ssh/id_rsa_github
  IdentitiesOnly yes
